{
  "name": "netflix-architecture",
  "version": "1.0.0",
  "description": "Netflix Architecture Demo with Nest.js - Resilience Patterns",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:gateway": "nest start gateway --watch",
    "start:recommendation": "nest start recommendation-svc --watch",
    "start:all": "concurrently \"npm run start:gateway\" \"npm run start:recommendation\"",
    "load-test": "node scripts/load-generator.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "opossum": "^8.1.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.0.0"
  }
}
